# CivicCare API — copy to .env and fill in values

# Required in production. Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-at-least-32-chars

# PostgreSQL (async driver for SQLAlchemy)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/civiccare

# Delhi wards GeoPackage for auto-ward at registration (optional; default: backend_tests/delhi_wards.gpkg if present)
# DELHI_WARDS_GPKG_PATH=/path/to/delhi_wards.gpkg

# Optional overrides (defaults shown)
# PROJECT_NAME=CivicCare API
# API_V1_STR=/api/v1
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=10080
# REFRESH_TOKEN_EXPIRE_DAYS=30
